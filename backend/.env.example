# Nuva backend config. Copy to .env for local dev. NEVER commit .env.
# Local dev works out of the box (SQLite) — you don't need to set much.

SECRET_KEY=dev-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Leave DATABASE_URL empty for local SQLite.
# For Supabase Postgres, use your project's connection string (add the DB password):
# DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@db.zliydmqixefzdiknbwol.supabase.co:5432/postgres
DATABASE_URL=

# Flutter origins allowed to call the API (comma-separated). Empty in DEBUG = allow all.
# e.g. CORS_ALLOWED_ORIGINS=https://zhar04.github.io,http://localhost:8088
CORS_ALLOWED_ORIGINS=

# JWT token lifetimes
ACCESS_TOKEN_MIN=30
REFRESH_TOKEN_DAYS=7

# Sprint 7 (Claude intake proxy) — server-side only, never ships in the app.
ANTHROPIC_API_KEY=
