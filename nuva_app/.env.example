# ─── Nuva backend API (Django) ────────────────────────────
# Local dev: http://localhost:8000 . Production: your Railway URL.
API_BASE_URL=http://localhost:8000

# ─── AI intake ────────────────────────────────────────────
# Nothing to set here. AI intake/matching goes through the Django backend
# (/api/v1/ai/{ask,match}); the ANTHROPIC_API_KEY lives only in Railway
# Variables and never ships in the app.

# ─── Backend (Supabase) ───────────────────────────────────
# Create a project at https://supabase.com (free), copy URL + anon key.
# Then run supabase/schema.sql in the SQL editor.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ─── Video calls (Jitsi) ──────────────────────────────────
# Public Jitsi instance for the in-app video room. meet.jit.si now gates
# anonymous rooms behind a "moderator must log in" screen, so the default is an
# open community server. Override here, e.g. with your own self-hosted domain
# (recommended for privacy — these are mental-health sessions). No https://, no
# trailing slash. Example: JITSI_DOMAIN=meet.ffmuc.net
JITSI_DOMAIN=meet.ffmuc.net

# ─── Error tracking (Sentry) ──────────────────────────────
# Optional. Sign up at https://sentry.io (free). Create a Flutter project,
# copy the DSN. Leave empty to disable.
SENTRY_DSN=
