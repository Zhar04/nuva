# Nuva app config (flutter_dotenv). Copy to .env and fill in.
#
#   cp .env.example .env
#
# IMPORTANT: .env ships INSIDE the web build (it's declared as a Flutter asset)
# and is extractable from build/web. Put ONLY client-safe values here — never a
# server secret. The ANTHROPIC_API_KEY and every other backend secret live in
# Railway → service → Variables and are reached through the Django backend.

# ─── Backend API (Django on Railway) ──────────────────────
# The deployed backend. A fresh clone talks to this immediately.
# Production: https://nuva-production.up.railway.app
API_BASE_URL=https://nuva-production.up.railway.app

# ─── Video calls (Jitsi) ──────────────────────────────────
# Public Jitsi instance for the in-app video room. No https://, no trailing
# slash. Self-host for production (mental-health sessions) — see docs/VIDEO_CALL.md.
JITSI_DOMAIN=meet.ffmuc.net
