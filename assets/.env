# ─── Nuva backend API (Django) ────────────────────────────
# Local dev: http://localhost:8000 . Production: your Railway URL.
API_BASE_URL=https://nuva-production.up.railway.app

# ─── AI intake ────────────────────────────────────────────
# Production: set CLAUDE_PROXY_URL pointing at your Cloudflare worker
# (see server/cloudflare-worker.js). Leave ANTHROPIC_API_KEY empty.
CLAUDE_PROXY_URL=
# Development only: direct Anthropic key (do NOT ship in production APK).
ANTHROPIC_API_KEY=

# ─── Backend (Supabase) ───────────────────────────────────
# Create a project at https://supabase.com (free), copy URL + anon key.
# Then run supabase/schema.sql in the SQL editor.
SUPABASE_URL=https://zliydmqixefzdiknbwol.supabase.co
SUPABASE_ANON_KEY=sb_publishable_9skKhDL0DL5ZbLz4vBamlw_5jpS396B

# ─── Video calls (Jitsi) ──────────────────────────────────
# Open public instance (meet.jit.si now requires a moderator login).
JITSI_DOMAIN=meet.ffmuc.net

# ─── Error tracking (Sentry) ──────────────────────────────
# Optional. Sign up at https://sentry.io (free). Create a Flutter project,
# copy the DSN. Leave empty to disable.
SENTRY_DSN=
